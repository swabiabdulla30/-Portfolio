{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/terms",
            "destination": "/terms.html"
        },
        {
            "source": "/privacy",
            "destination": "/privacy.html"
        },
        {
            "source": "/shipping",
            "destination": "/shipping.html"
        },
        {
            "source": "/refunds",
            "destination": "/refunds.html"
        }
    ]
}